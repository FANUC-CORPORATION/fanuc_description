<!-- URDF for M-710/70-21D (M-710iD/70) -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro
    name="m710id_70"
    params="prefix=''
            parent
            *origin
            child"
  >

    <xacro:property name="j1_lower_limit" value="${radians(-185)}" />
    <xacro:property name="j2_lower_limit" value="${radians(-75)}" />
    <xacro:property name="j3_lower_limit" value="${radians(-80.5)}" />
    <xacro:property name="j4_lower_limit" value="${radians(-400)}" />
    <xacro:property name="j5_lower_limit" value="${radians(-125)}" />
    <xacro:property name="j6_lower_limit" value="${radians(-400)}" />

    <xacro:property name="j1_upper_limit" value="${radians(185)}" />
    <xacro:property name="j2_upper_limit" value="${radians(150)}" />
    <xacro:property name="j3_upper_limit" value="${radians(205)}" />
    <xacro:property name="j4_upper_limit" value="${radians(400)}" />
    <xacro:property name="j5_upper_limit" value="${radians(125)}" />
    <xacro:property name="j6_upper_limit" value="${radians(400)}" />

    <xacro:property name="j1_effort_limit" value="8000" />
    <xacro:property name="j2_effort_limit" value="10000" />
    <xacro:property name="j3_effort_limit" value="5000" />
    <xacro:property name="j4_effort_limit" value="2000" />
    <xacro:property name="j5_effort_limit" value="1000" />
    <xacro:property name="j6_effort_limit" value="900" />

    <xacro:property name="j1_velocity_limit" value="${radians(180)}" />
    <xacro:property name="j2_velocity_limit" value="${radians(180)}" />
    <xacro:property name="j3_velocity_limit" value="${radians(180)}" />
    <xacro:property name="j4_velocity_limit" value="${radians(260)}" />
    <xacro:property name="j5_velocity_limit" value="${radians(260)}" />
    <xacro:property name="j6_velocity_limit" value="${radians(370)}" />

    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/base.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/base.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 115" />
        <origin xyz="-.0562 -.000509  .109" />
        <inertia
          ixx=" 2.95"
          ixy="-.0346"
          ixz=" .0263"
          iyy=" 3.15"
          iyz=" .00171"
          izz=" 5.12"
        />
      </inertial>
    </link>

    <link name="${prefix}J1_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/j1.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/j1.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 189" />
        <origin xyz=" .0361 -.00394 -.0874" />
        <inertia
          ixx=" 7.22"
          ixy=" .238"
          ixz="-.646"
          iyy=" 5.83"
          iyz=" .444"
          izz=" 7.43"
        />
      </inertial>
    </link>

    <link name="${prefix}J2_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/j2.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/j2.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 137" />
        <origin xyz="-.0291  .17  .4" />
        <inertia
          ixx=" 13.3"
          ixy=" .0925"
          ixz="-.0231"
          iyy=" 14.2"
          iyz="-1.14"
          izz=" 1.9"
        />
      </inertial>
    </link>

    <link name="${prefix}J3_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/j3.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/j3.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 93.9" />
        <origin xyz=" .0255 -.005  .0679" />
        <inertia
          ixx=" 2"
          ixy="-.0815"
          ixz="-.327"
          iyy=" 2.53"
          iyz="-.0631"
          izz=" 2.02"
        />
      </inertial>
    </link>

    <link name="${prefix}J4_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/j4.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/j4.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 34.8" />
        <origin xyz=" .612 -.00489  .000279" />
        <inertia
          ixx=" .14"
          ixy=" .012"
          ixz="-.000192"
          iyy=" 1.83"
          iyz="-.000335"
          izz=" 1.83"
        />
      </inertial>
    </link>

    <link name="${prefix}J5_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/j5.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/j5.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 10.2" />
        <origin xyz=" .0344 -.0134  .0000000923" />
        <inertia
          ixx=" .0448"
          ixy="-.00501"
          ixz="-.000000106"
          iyy=" .0525"
          iyz="-.00000028"
          izz=" .0678"
        />
      </inertial>
    </link>

    <link name="${prefix}J6_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/visual/j6.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710id_70/collision/j6.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" .447" />
        <origin xyz=" .165 -7.3E-19  3.24E-19" />
        <inertia
          ixx=" .000872"
          ixy="-1.22E-19"
          ixz="-4.86E-20"
          iyy=" .000451"
          iyz="-1.66E-21"
          izz=" .000451"
        />
      </inertial>
    </link>

    <!-- joints -->
    <joint name="${prefix}J1" type="revolute">
      <origin xyz=" 0  0  .565" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}J1_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j1_lower_limit}"
        upper="${j1_upper_limit}"
        effort="${j1_effort_limit}"
        velocity="${j1_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J2" type="revolute">
      <origin xyz=" .15  0  0" rpy="0 0 0" />
      <parent link="${prefix}J1_link" />
      <child link="${prefix}J2_link" />
      <axis xyz=" 0  1  0" />
      <limit
        lower="${j2_lower_limit}"
        upper="${j2_upper_limit}"
        effort="${j2_effort_limit}"
        velocity="${j2_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J3" type="revolute">
      <origin xyz=" 0  0  .895" rpy="0 0 0" />
      <parent link="${prefix}J2_link" />
      <child link="${prefix}J3_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j3_lower_limit}"
        upper="${j3_upper_limit}"
        effort="${j3_effort_limit}"
        velocity="${j3_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J4" type="revolute">
      <origin xyz=" 0  0  .17" rpy="0 0 0" />
      <parent link="${prefix}J3_link" />
      <child link="${prefix}J4_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j4_lower_limit}"
        upper="${j4_upper_limit}"
        effort="${j4_effort_limit}"
        velocity="${j4_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J5" type="revolute">
      <origin xyz=" 1.045  0  0" rpy="0 0 0" />
      <parent link="${prefix}J4_link" />
      <child link="${prefix}J5_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j5_lower_limit}"
        upper="${j5_upper_limit}"
        effort="${j5_effort_limit}"
        velocity="${j5_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J6" type="revolute">
      <origin xyz=" 0  0  0" rpy="0 0 0" />
      <parent link="${prefix}J5_link" />
      <child link="${prefix}J6_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j6_lower_limit}"
        upper="${j6_upper_limit}"
        effort="${j6_effort_limit}"
        velocity="${j6_velocity_limit}"
      />
    </joint>

    <!-- world coords -->
    <link name="${prefix}wbase" />
    <joint name="${prefix}base_link-wbase" type="fixed">
      <origin xyz=" 0  0  .565" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wbase" />
    </joint>

    <!-- flange coords -->
    <link name="${prefix}flange" />
    <joint name="${prefix}J6-flange" type="fixed">
      <origin xyz=" .175  0  0" rpy="0 0 0" />
      <parent link="${prefix}J6_link" />
      <child link="${prefix}flange" />
    </joint>

    <!-- FANUC flange coords -->
    <link name="${prefix}fanuc_flange" />
    <joint name="${prefix}flange-fanuc_flange" type="fixed">
      <origin xyz="0 0 0" rpy="${radians( 180)} ${radians(-90)} ${radians( 0)}" />
      <parent link="${prefix}flange" />
      <child link="${prefix}fanuc_flange" />
    </joint>

    <!-- Attach to parent -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}base_link" />
    </joint>

    <!-- Attach child -->
    <joint name="${prefix}child_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}flange" />
      <child link="${child}" />
    </joint>
  </xacro:macro>
</robot>
