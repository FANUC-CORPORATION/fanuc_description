<!-- URDF for M-710iC/50E -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro
    name="m710ic_50e"
    params="prefix=''
            parent
            *origin
            child"
  >

    <xacro:property name="j1_lower_limit" value="${radians(-180)}" />
    <xacro:property name="j2_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j3_lower_limit" value="${radians(-80.5)}" />
    <xacro:property name="j4_lower_limit" value="${radians(-360)}" />
    <xacro:property name="j5_lower_limit" value="${radians(-190)}" />
    <xacro:property name="j6_lower_limit" value="${radians(-360)}" />

    <xacro:property name="j1_upper_limit" value="${radians(180)}" />
    <xacro:property name="j2_upper_limit" value="${radians(135)}" />
    <xacro:property name="j3_upper_limit" value="${radians(205)}" />
    <xacro:property name="j4_upper_limit" value="${radians(360)}" />
    <xacro:property name="j5_upper_limit" value="${radians(190)}" />
    <xacro:property name="j6_upper_limit" value="${radians(360)}" />

    <xacro:property name="j1_effort_limit" value="5000" />
    <xacro:property name="j2_effort_limit" value="7000" />
    <xacro:property name="j3_effort_limit" value="6000" />
    <xacro:property name="j4_effort_limit" value="800" />
    <xacro:property name="j5_effort_limit" value="700" />
    <xacro:property name="j6_effort_limit" value="400" />

    <xacro:property name="j1_velocity_limit" value="${radians(175)}" />
    <xacro:property name="j2_velocity_limit" value="${radians(175)}" />
    <xacro:property name="j3_velocity_limit" value="${radians(175)}" />
    <xacro:property name="j4_velocity_limit" value="${radians(250)}" />
    <xacro:property name="j5_velocity_limit" value="${radians(240)}" />
    <xacro:property name="j6_velocity_limit" value="${radians(340)}" />

    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/base.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/base.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 131" />
        <origin xyz="-.0493 -.000226  .119" />
        <inertia
          ixx=" 3.47"
          ixy=" .00926"
          ixz=" .0525"
          iyy=" 3.55"
          iyz="-.00431"
          izz=" 5.65"
        />
      </inertial>
    </link>

    <link name="${prefix}J1_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/j1.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/j1.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 202" />
        <origin xyz=" .0515 -.00696 -.105" />
        <inertia
          ixx=" 7.56"
          ixy="-.336"
          ixz="-.511"
          iyy=" 6.45"
          iyz=" .22"
          izz=" 8.09"
        />
      </inertial>
    </link>

    <link name="${prefix}J2_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/j2.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/j2.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 91.5" />
        <origin xyz=" .00284  .154  .344" />
        <inertia
          ixx=" 7.91"
          ixy=" .023"
          ixz=" .00161"
          iyy=" 8.18"
          iyz="-.306"
          izz=" .76"
        />
      </inertial>
    </link>

    <link name="${prefix}J3_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/j3.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/j3.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 95.9" />
        <origin xyz=" .0214 -.0311  .087" />
        <inertia
          ixx=" 1.85"
          ixy="-.184"
          ixz="-.246"
          iyy=" 2.42"
          iyz="-.0984"
          izz=" 2.18"
        />
      </inertial>
    </link>

    <link name="${prefix}J4_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/j4.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/j4.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 34.4" />
        <origin xyz=" .683 -.00000164  .0276" />
        <inertia
          ixx=" .137"
          ixy="-.0000000153"
          ixz="-.128"
          iyy=" 1.76"
          iyz=" .00000748"
          izz=" 1.73"
        />
      </inertial>
    </link>

    <link name="${prefix}J5_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/j5.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/j5.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 4.76" />
        <origin xyz=" .0608 -.000319  .156" />
        <inertia
          ixx=" .00983"
          ixy="-.0000229"
          ixz="-.00129"
          iyy=" .0192"
          iyz="-.0000244"
          izz=" .0205"
        />
      </inertial>
    </link>

    <link name="${prefix}J6_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/visual/j6.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m710_description/meshes/m710ic_50e/collision/j6.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" .37" />
        <origin xyz=" .162  .00000000106 -4.91E-18" />
        <inertia
          ixx=" .000702"
          ixy=" .0000000000017"
          ixz="-2.01E-19"
          iyy=" .000359"
          iyz="-2.84E-20"
          izz=" .000359"
        />
      </inertial>
    </link>

    <!-- joints -->
    <joint name="${prefix}J1" type="revolute">
      <origin xyz=" 0  0  .565" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}J1_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j1_lower_limit}"
        upper="${j1_upper_limit}"
        effort="${j1_effort_limit}"
        velocity="${j1_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J2" type="revolute">
      <origin xyz=" .15  0  0" rpy="0 0 0" />
      <parent link="${prefix}J1_link" />
      <child link="${prefix}J2_link" />
      <axis xyz=" 0  1  0" />
      <limit
        lower="${j2_lower_limit}"
        upper="${j2_upper_limit}"
        effort="${j2_effort_limit}"
        velocity="${j2_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J3" type="revolute">
      <origin xyz=" 0  0  .87" rpy="0 0 0" />
      <parent link="${prefix}J2_link" />
      <child link="${prefix}J3_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j3_lower_limit}"
        upper="${j3_upper_limit}"
        effort="${j3_effort_limit}"
        velocity="${j3_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J4" type="revolute">
      <origin xyz=" 0  0  .17" rpy="0 0 0" />
      <parent link="${prefix}J3_link" />
      <child link="${prefix}J4_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j4_lower_limit}"
        upper="${j4_upper_limit}"
        effort="${j4_effort_limit}"
        velocity="${j4_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J5" type="revolute">
      <origin xyz=" 1.016  0  0" rpy="0 0 0" />
      <parent link="${prefix}J4_link" />
      <child link="${prefix}J5_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j5_lower_limit}"
        upper="${j5_upper_limit}"
        effort="${j5_effort_limit}"
        velocity="${j5_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J6" type="revolute">
      <origin xyz=" 0  0  .16" rpy="0 0 0" />
      <parent link="${prefix}J5_link" />
      <child link="${prefix}J6_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j6_lower_limit}"
        upper="${j6_upper_limit}"
        effort="${j6_effort_limit}"
        velocity="${j6_velocity_limit}"
      />
    </joint>

    <!-- world coords -->
    <link name="${prefix}wbase" />
    <joint name="${prefix}base_link-wbase" type="fixed">
      <origin xyz=" 0  0  .565" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wbase" />
    </joint>

    <!-- flange coords -->
    <link name="${prefix}flange" />
    <joint name="${prefix}J6-flange" type="fixed">
      <origin xyz=" .17  0  0" rpy="0 0 0" />
      <parent link="${prefix}J6_link" />
      <child link="${prefix}flange" />
    </joint>

    <!-- FANUC flange coords -->
    <link name="${prefix}fanuc_flange" />
    <joint name="${prefix}flange-fanuc_flange" type="fixed">
      <origin xyz="0 0 0" rpy="${radians( 180)} ${radians(-90)} ${radians( 0)}" />
      <parent link="${prefix}flange" />
      <child link="${prefix}fanuc_flange" />
    </joint>

    <!-- Attach to parent -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}base_link" />
    </joint>

    <!-- Attach child -->
    <joint name="${prefix}child_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}flange" />
      <child link="${child}" />
    </joint>
  </xacro:macro>
</robot>
