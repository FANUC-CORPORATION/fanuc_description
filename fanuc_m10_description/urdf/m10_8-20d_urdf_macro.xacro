<!-- URDF for M-10/8-20D(M-10iD/8L) -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro
    name="m10_8-20d"
    params="prefix=''
            parent
            *origin
            child"
  >

    <xacro:property name="j1_lower_limit" value="${radians(-185)}" />
    <xacro:property name="j2_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j3_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j4_lower_limit" value="${radians(-190)}" />
    <xacro:property name="j5_lower_limit" value="${radians(-179.999)}" />
    <xacro:property name="j6_lower_limit" value="${radians(-450)}" />

    <xacro:property name="j1_upper_limit" value="${radians(185)}" />
    <xacro:property name="j2_upper_limit" value="${radians(145)}" />
    <xacro:property name="j3_upper_limit" value="${radians(222)}" />
    <xacro:property name="j4_upper_limit" value="${radians(190)}" />
    <xacro:property name="j5_upper_limit" value="${radians(179.999)}" />
    <xacro:property name="j6_upper_limit" value="${radians(450)}" />

    <xacro:property name="j1_effort_limit" value="2000" />
    <xacro:property name="j2_effort_limit" value="3000" />
    <xacro:property name="j3_effort_limit" value="1000" />
    <xacro:property name="j4_effort_limit" value="100" />
    <xacro:property name="j5_effort_limit" value="100" />
    <xacro:property name="j6_effort_limit" value="50" />

    <xacro:property name="j1_velocity_limit" value="${radians(210)}" />
    <xacro:property name="j2_velocity_limit" value="${radians(210)}" />
    <xacro:property name="j3_velocity_limit" value="${radians(220)}" />
    <xacro:property name="j4_velocity_limit" value="${radians(430)}" />
    <xacro:property name="j5_velocity_limit" value="${radians(450)}" />
    <xacro:property name="j6_velocity_limit" value="${radians(720)}" />

    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/base.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/base.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 48" />
        <origin xyz=" .00757 -.0212  .138" />
        <inertia
          ixx=" .791"
          ixy=" .0324"
          ixz="-.0279"
          iyy=" .79"
          iyz=" .0527"
          izz=" .952"
        />
      </inertial>
    </link>

    <link name="${prefix}J1_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/j1.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/j1.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 25.1" />
        <origin xyz=" .0385 -.0176 -.0359" />
        <inertia
          ixx=" .285"
          ixy="-.0106"
          ixz="-.0157"
          iyy=" .242"
          iyz="-.00898"
          izz=" .336"
        />
      </inertial>
    </link>

    <link name="${prefix}J2_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/j2.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/j2.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 33.5" />
        <origin xyz="-.0227 -.151  .402" />
        <inertia
          ixx=" 2.3"
          ixy="-.0223"
          ixz=" .0191"
          iyy=" 2.33"
          iyz="-.0412"
          izz=" .152"
        />
      </inertial>
    </link>

    <link name="${prefix}J3_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/j3.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/j3.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 54.5" />
        <origin xyz=" .242  .0064  .116" />
        <inertia
          ixx=" .693"
          ixy="-.0249"
          ixz="-.368"
          iyy=" 2.13"
          iyz="-.035"
          izz=" 2.1"
        />
      </inertial>
    </link>

    <link name="${prefix}J4_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/j4.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/j4.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 17.5" />
        <origin xyz=" .678 -.0311 -.000832" />
        <inertia
          ixx=" .0509"
          ixy=" .0696"
          ixz=" .000437"
          iyy=" .9"
          iyz="-.000433"
          izz=" .915"
        />
      </inertial>
    </link>

    <link name="${prefix}J5_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/j5.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/j5.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 1.16" />
        <origin xyz=" .0214 -.015  .0000000000494" />
        <inertia
          ixx=" .00173"
          ixy="-.000392"
          ixz=" .00000000000155"
          iyy=" .00191"
          iyz=" .00000000000141"
          izz=" .00189"
        />
      </inertial>
    </link>

    <link name="${prefix}J6_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/visual/j6.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_8-20d/collision/j6.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" .224" />
        <origin xyz=" .0537  .000000457  .00000541" />
        <inertia
          ixx=" .000131"
          ixy="-.000000000116"
          ixz="-.00000000799"
          iyy=" .000102"
          iyz="-.00000000000398"
          izz=" .000102"
        />
      </inertial>
    </link>

    <!-- joints -->
    <joint name="${prefix}J1" type="revolute">
      <origin xyz=" 0  0  .45" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}J1_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j1_lower_limit}"
        upper="${j1_upper_limit}"
        effort="${j1_effort_limit}"
        velocity="${j1_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J2" type="revolute">
      <origin xyz=" .075  0  0" rpy="0 0 0" />
      <parent link="${prefix}J1_link" />
      <child link="${prefix}J2_link" />
      <axis xyz=" 0  1  0" />
      <limit
        lower="${j2_lower_limit}"
        upper="${j2_upper_limit}"
        effort="${j2_effort_limit}"
        velocity="${j2_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J3" type="revolute">
      <origin xyz=" 0  0  .84" rpy="0 0 0" />
      <parent link="${prefix}J2_link" />
      <child link="${prefix}J3_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j3_lower_limit}"
        upper="${j3_upper_limit}"
        effort="${j3_effort_limit}"
        velocity="${j3_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J4" type="revolute">
      <origin xyz=" 0  0  .195" rpy="0 0 0" />
      <parent link="${prefix}J3_link" />
      <child link="${prefix}J4_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j4_lower_limit}"
        upper="${j4_upper_limit}"
        effort="${j4_effort_limit}"
        velocity="${j4_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J5" type="revolute">
      <origin xyz=" 1.1  0  0" rpy="0 0 0" />
      <parent link="${prefix}J4_link" />
      <child link="${prefix}J5_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j5_lower_limit}"
        upper="${j5_upper_limit}"
        effort="${j5_effort_limit}"
        velocity="${j5_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J6" type="revolute">
      <origin xyz=" 0  0  0" rpy="0 0 0" />
      <parent link="${prefix}J5_link" />
      <child link="${prefix}J6_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j6_lower_limit}"
        upper="${j6_upper_limit}"
        effort="${j6_effort_limit}"
        velocity="${j6_velocity_limit}"
      />
    </joint>

    <!-- world coords -->
    <link name="${prefix}wbase" />
    <joint name="${prefix}base_link-wbase" type="fixed">
      <origin xyz=" 0  0  .45" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wbase" />
    </joint>

    <!-- flange coords -->
    <link name="${prefix}flange" />
    <joint name="${prefix}J6-flange" type="fixed">
      <origin xyz=" .075  0  0" rpy="0 0 0" />
      <parent link="${prefix}J6_link" />
      <child link="${prefix}flange" />
    </joint>

    <!-- FANUC flange coords -->
    <link name="${prefix}fanuc_flange" />
    <joint name="${prefix}flange-fanuc_flange" type="fixed">
      <origin xyz="0 0 0" rpy="${radians( 180)} ${radians(-90)} ${radians( 0)}" />
      <parent link="${prefix}flange" />
      <child link="${prefix}fanuc_flange" />
    </joint>

    <!-- Attach to parent -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}base_link" />
    </joint>

    <!-- Attach child -->
    <joint name="${prefix}child_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}flange" />
      <child link="${child}" />
    </joint>
  </xacro:macro>
</robot>
