<!-- URDF for M-10/10-16D (M-10iD/10L) -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro
    name="m10_10-16d"
    params="prefix=''
            parent
            *origin
            child"
  >

    <xacro:property name="j1_lower_limit" value="${radians(-185)}" />
    <xacro:property name="j2_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j3_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j4_lower_limit" value="${radians(-190)}" />
    <xacro:property name="j5_lower_limit" value="${radians(-180)}" />
    <xacro:property name="j6_lower_limit" value="${radians(-450)}" />

    <xacro:property name="j1_upper_limit" value="${radians(185)}" />
    <xacro:property name="j2_upper_limit" value="${radians(145)}" />
    <xacro:property name="j3_upper_limit" value="${radians(222)}" />
    <xacro:property name="j4_upper_limit" value="${radians(190)}" />
    <xacro:property name="j5_upper_limit" value="${radians(180)}" />
    <xacro:property name="j6_upper_limit" value="${radians(450)}" />

    <xacro:property name="j1_effort_limit" value="2000" />
    <xacro:property name="j2_effort_limit" value="3000" />
    <xacro:property name="j3_effort_limit" value="1000" />
    <xacro:property name="j4_effort_limit" value="100" />
    <xacro:property name="j5_effort_limit" value="100" />
    <xacro:property name="j6_effort_limit" value="50" />

    <xacro:property name="j1_velocity_limit" value="${radians(260)}" />
    <xacro:property name="j2_velocity_limit" value="${radians(240)}" />
    <xacro:property name="j3_velocity_limit" value="${radians(260)}" />
    <xacro:property name="j4_velocity_limit" value="${radians(430)}" />
    <xacro:property name="j5_velocity_limit" value="${radians(450)}" />
    <xacro:property name="j6_velocity_limit" value="${radians(720)}" />

    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/base.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/base.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 50.6" />
        <origin xyz=" .00757 -.0212  .138" />
        <inertia
          ixx=" .834"
          ixy=" .0342"
          ixz="-.0294"
          iyy=" .833"
          iyz=" .0556"
          izz=" 1"
        />
      </inertial>
    </link>

    <link name="${prefix}J1_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/j1.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/j1.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 26.5" />
        <origin xyz=" .0385 -.0176 -.0359" />
        <inertia
          ixx=" .3"
          ixy="-.0111"
          ixz="-.0166"
          iyy=" .255"
          iyz="-.00947"
          izz=" .354"
        />
      </inertial>
    </link>

    <link name="${prefix}J2_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/j2.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/j2.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 26" />
        <origin xyz="-.0225 -.149  .305" />
        <inertia
          ixx=" 1.11"
          ixy="-.0176"
          ixz=" .0118"
          iyy=" 1.12"
          iyz="-.0238"
          izz=" .113"
        />
      </inertial>
    </link>

    <link name="${prefix}J3_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/j3.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/j3.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 31.3" />
        <origin xyz=" .11  .00824  .0948" />
        <inertia
          ixx=" .455"
          ixy="-.0273"
          ixz="-.102"
          iyy=" .414"
          iyz="-.0248"
          izz=" .417"
        />
      </inertial>
    </link>

    <link name="${prefix}J4_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/j4.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/j4.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 14.1" />
        <origin xyz=" .568 -.0354 -.000882" />
        <inertia
          ixx=" .041"
          ixy=" .0424"
          ixz="-.000132"
          iyy=" .431"
          iyz="-.000355"
          izz=" .444"
        />
      </inertial>
    </link>

    <link name="${prefix}J5_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/j5.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/j5.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 1.23" />
        <origin xyz=" .0214 -.015  .0000000000494" />
        <inertia
          ixx=" .00182"
          ixy="-.000414"
          ixz=" .00000000000164"
          iyy=" .00202"
          iyz=" .00000000000149"
          izz=" .00199"
        />
      </inertial>
    </link>

    <link name="${prefix}J6_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/visual/j6.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m10_description/meshes/m10_10-16d/collision/j6.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" .236" />
        <origin xyz=" .0537  .000000457  .00000541" />
        <inertia
          ixx=" .000138"
          ixy="-.000000000122"
          ixz="-.00000000842"
          iyy=" .000107"
          iyz="-.00000000000419"
          izz=" .000107"
        />
      </inertial>
    </link>

    <!-- joints -->
    <joint name="${prefix}J1" type="revolute">
      <origin xyz=" 0  0  .45" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}J1_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j1_lower_limit}"
        upper="${j1_upper_limit}"
        effort="${j1_effort_limit}"
        velocity="${j1_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J2" type="revolute">
      <origin xyz=" .075  0  0" rpy="0 0 0" />
      <parent link="${prefix}J1_link" />
      <child link="${prefix}J2_link" />
      <axis xyz=" 0  1  0" />
      <limit
        lower="${j2_lower_limit}"
        upper="${j2_upper_limit}"
        effort="${j2_effort_limit}"
        velocity="${j2_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J3" type="revolute">
      <origin xyz=" 0  0  .64" rpy="0 0 0" />
      <parent link="${prefix}J2_link" />
      <child link="${prefix}J3_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j3_lower_limit}"
        upper="${j3_upper_limit}"
        effort="${j3_effort_limit}"
        velocity="${j3_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J4" type="revolute">
      <origin xyz=" 0  0  .195" rpy="0 0 0" />
      <parent link="${prefix}J3_link" />
      <child link="${prefix}J4_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j4_lower_limit}"
        upper="${j4_upper_limit}"
        effort="${j4_effort_limit}"
        velocity="${j4_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J5" type="revolute">
      <origin xyz=" .9  0  0" rpy="0 0 0" />
      <parent link="${prefix}J4_link" />
      <child link="${prefix}J5_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j5_lower_limit}"
        upper="${j5_upper_limit}"
        effort="${j5_effort_limit}"
        velocity="${j5_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J6" type="revolute">
      <origin xyz=" 0  0  0" rpy="0 0 0" />
      <parent link="${prefix}J5_link" />
      <child link="${prefix}J6_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j6_lower_limit}"
        upper="${j6_upper_limit}"
        effort="${j6_effort_limit}"
        velocity="${j6_velocity_limit}"
      />
    </joint>

    <!-- world coords -->
    <link name="${prefix}wbase" />
    <joint name="${prefix}base_link-wbase" type="fixed">
      <origin xyz=" 0  0  .45" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wbase" />
    </joint>

    <!-- flange coords -->
    <link name="${prefix}flange" />
    <joint name="${prefix}J6-flange" type="fixed">
      <origin xyz=" .075  0  0" rpy="0 0 0" />
      <parent link="${prefix}J6_link" />
      <child link="${prefix}flange" />
    </joint>

    <!-- FANUC flange coords -->
    <link name="${prefix}fanuc_flange" />
    <joint name="${prefix}flange-fanuc_flange" type="fixed">
      <origin xyz="0 0 0" rpy="${radians( 180)} ${radians(-90)} ${radians( 0)}" />
      <parent link="${prefix}flange" />
      <child link="${prefix}fanuc_flange" />
    </joint>

    <!-- Attach to parent -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}base_link" />
    </joint>

    <!-- Attach child -->
    <joint name="${prefix}child_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}flange" />
      <child link="${child}" />
    </joint>
  </xacro:macro>
</robot>
