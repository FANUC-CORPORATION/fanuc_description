<!-- URDF for M800/60-20B (M-800iB/60) -->
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro
    name="m800_60_20b"
    params="prefix=''
            parent
            *origin
            child"
  >

    <xacro:property name="j1_lower_limit" value="${radians(-185)}" />
    <xacro:property name="j2_lower_limit" value="${radians(-90)}" />
    <xacro:property name="j3_lower_limit" value="${radians(-77)}" />
    <xacro:property name="j4_lower_limit" value="${radians(-360)}" />
    <xacro:property name="j5_lower_limit" value="${radians(-125)}" />
    <xacro:property name="j6_lower_limit" value="${radians(-360)}" />

    <xacro:property name="j1_upper_limit" value="${radians(185)}" />
    <xacro:property name="j2_upper_limit" value="${radians(135)}" />
    <xacro:property name="j3_upper_limit" value="${radians(140)}" />
    <xacro:property name="j4_upper_limit" value="${radians(360)}" />
    <xacro:property name="j5_upper_limit" value="${radians(125)}" />
    <xacro:property name="j6_upper_limit" value="${radians(360)}" />

    <xacro:property name="j1_effort_limit" value="10000" />
    <xacro:property name="j2_effort_limit" value="10000" />
    <xacro:property name="j3_effort_limit" value="7000" />
    <xacro:property name="j4_effort_limit" value="2000" />
    <xacro:property name="j5_effort_limit" value="1000" />
    <xacro:property name="j6_effort_limit" value="600" />

    <xacro:property name="j1_velocity_limit" value="${radians(150)}" />
    <xacro:property name="j2_velocity_limit" value="${radians(150)}" />
    <xacro:property name="j3_velocity_limit" value="${radians(150)}" />
    <xacro:property name="j4_velocity_limit" value="${radians(260)}" />
    <xacro:property name="j5_velocity_limit" value="${radians(260)}" />
    <xacro:property name="j6_velocity_limit" value="${radians(400)}" />

    <!-- links -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/base.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/base.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 211" />
        <origin xyz="-.135  .00064  .131" />
        <inertia
          ixx=" 5.54"
          ixy=" .148"
          ixz="-.404"
          iyy=" 11.2"
          iyz=" .0289"
          izz=" 14.2"
        />
      </inertial>
    </link>

    <link name="${prefix}J1_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/j1.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/j1.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 251" />
        <origin xyz=" .124  .0126 -.109" />
        <inertia
          ixx=" 9.2"
          ixy="-.405"
          ixz="-2.62"
          iyy=" 11.3"
          iyz="-.245"
          izz=" 12.9"
        />
      </inertial>
    </link>

    <link name="${prefix}J2_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/j2.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/j2.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 145" />
        <origin xyz=" .00223  .157  .388" />
        <inertia
          ixx=" 13.3"
          ixy="-.0333"
          ixz="-.0318"
          iyy=" 13.8"
          iyz=" .154"
          izz=" 1.68"
        />
      </inertial>
    </link>

    <link name="${prefix}J3_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/j3.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/j3.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 141" />
        <origin xyz=" .0772  .0191  .106" />
        <inertia
          ixx=" 4.53"
          ixy="-.0941"
          ixz="-.912"
          iyy=" 3.63"
          iyz="-.113"
          izz=" 4.23"
        />
      </inertial>
    </link>

    <link name="${prefix}J4_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/j4.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/j4.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 59.9" />
        <origin xyz=" .656 -.000349 -.000145" />
        <inertia
          ixx=" .457"
          ixy="-.00541"
          ixz="-.000528"
          iyy=" 2.15"
          iyz=" .0000124"
          izz=" 2.3"
        />
      </inertial>
    </link>

    <link name="${prefix}J5_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/j5.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/j5.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" 11.9" />
        <origin xyz=" .0553 -.00233 -.00363" />
        <inertia
          ixx=" .0435"
          ixy="-.000653"
          ixz=" .00233"
          iyy=" .0858"
          iyz="-.000142"
          izz=" .0824"
        />
      </inertial>
    </link>

    <link name="${prefix}J6_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/visual/j6.dae"
          />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh
            filename="package://fanuc_m800_description/meshes/m800_60_20b/collision/j6.stl"
          />
        </geometry>
      </collision>
      <inertial>
        <mass value=" .733" />
        <origin xyz=" .174  2.29E-18  3.93E-18" />
        <inertia
          ixx=" .00125"
          ixy=" 1.27E-18"
          ixz=" 8.86E-19"
          iyy=" .000692"
          iyz=" .0000000000517"
          izz=" .000692"
        />
      </inertial>
    </link>

    <!-- joints -->
    <joint name="${prefix}J1" type="revolute">
      <origin xyz=" 0  0  .6" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}J1_link" />
      <axis xyz=" 0  0  1" />
      <limit
        lower="${j1_lower_limit}"
        upper="${j1_upper_limit}"
        effort="${j1_effort_limit}"
        velocity="${j1_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J2" type="revolute">
      <origin xyz=" .312  0  0" rpy="0 0 0" />
      <parent link="${prefix}J1_link" />
      <child link="${prefix}J2_link" />
      <axis xyz=" 0  1  0" />
      <limit
        lower="${j2_lower_limit}"
        upper="${j2_upper_limit}"
        effort="${j2_effort_limit}"
        velocity="${j2_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J3" type="revolute">
      <origin xyz=" 0  0  .8" rpy="0 0 0" />
      <parent link="${prefix}J2_link" />
      <child link="${prefix}J3_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j3_lower_limit}"
        upper="${j3_upper_limit}"
        effort="${j3_effort_limit}"
        velocity="${j3_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J4" type="revolute">
      <origin xyz=" 0  0  .225" rpy="0 0 0" />
      <parent link="${prefix}J3_link" />
      <child link="${prefix}J4_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j4_lower_limit}"
        upper="${j4_upper_limit}"
        effort="${j4_effort_limit}"
        velocity="${j4_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J5" type="revolute">
      <origin xyz=" .9  0  0" rpy="0 0 0" />
      <parent link="${prefix}J4_link" />
      <child link="${prefix}J5_link" />
      <axis xyz=" 0 -1  0" />
      <limit
        lower="${j5_lower_limit}"
        upper="${j5_upper_limit}"
        effort="${j5_effort_limit}"
        velocity="${j5_velocity_limit}"
      />
    </joint>

    <joint name="${prefix}J6" type="revolute">
      <origin xyz=" 0  0  0" rpy="0 0 0" />
      <parent link="${prefix}J5_link" />
      <child link="${prefix}J6_link" />
      <axis xyz="-1  0  0" />
      <limit
        lower="${j6_lower_limit}"
        upper="${j6_upper_limit}"
        effort="${j6_effort_limit}"
        velocity="${j6_velocity_limit}"
      />
    </joint>

    <!-- world coords -->
    <link name="${prefix}wbase" />
    <joint name="${prefix}base_link-wbase" type="fixed">
      <origin xyz=" 0  0  .6" rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}wbase" />
    </joint>

    <!-- flange coords -->
    <link name="${prefix}flange" />
    <joint name="${prefix}J6-flange" type="fixed">
      <origin xyz=" .19  0  0" rpy="0 0 0" />
      <parent link="${prefix}J6_link" />
      <child link="${prefix}flange" />
    </joint>

    <!-- FANUC flange coords -->
    <link name="${prefix}fanuc_flange" />
    <joint name="${prefix}flange-fanuc_flange" type="fixed">
      <origin xyz="0 0 0" rpy="${radians( 180)} ${radians(-90)} ${radians( 0)}" />
      <parent link="${prefix}flange" />
      <child link="${prefix}fanuc_flange" />
    </joint>

    <!-- Attach to parent -->
    <joint name="${prefix}base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}base_link" />
    </joint>

    <!-- Attach child -->
    <joint name="${prefix}child_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="${prefix}flange" />
      <child link="${child}" />
    </joint>
  </xacro:macro>
</robot>
